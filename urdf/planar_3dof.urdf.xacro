<?xml version="1.0"?>
<robot name="planar_3dof" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ========================= -->
  <!-- ARGUMENTS -->
  <!-- ========================= -->
  <xacro:arg name="pkg_share" default=""/>
  <xacro:arg name="controllers_yaml" default=""/>
  <xacro:arg name="mesh_scale" default="1 1 1"/>
  <xacro:arg name="fix_to_world" default="false"/>

  <xacro:property name="pkg_share" value="$(arg pkg_share)"/>
  <xacro:property name="controllers_yaml" value="$(arg controllers_yaml)"/>
  <xacro:property name="mesh_scale" value="$(arg mesh_scale)"/>
  <xacro:property name="fix_to_world" value="$(arg fix_to_world)"/>

  <!-- ========================= -->
  <!-- BASE LINK -->
  <!-- ========================= -->
  <link name="base_link">
    <inertial>
      <origin xyz="-0.24659 0 0" rpy="0 0 0"/>
      <mass value="11.35"/>  
      <inertia ixx="180.49" ixy="0" ixz="0"
               iyy="21.405" iyz="0" izz="181.05"/>
    </inertial>

    <visual>
      <geometry>
        <mesh filename="file://${pkg_share}/meshes/base_link.STL"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <mesh filename="file://${pkg_share}/meshes/base_link.STL"/>
      </geometry>
    </collision>
  </link>

  <!-- ========================= -->
  <!-- LEG MACRO -->
  <!-- ========================= -->
  <xacro:macro name="leg" params="side parent y_offset rpy_c rpy_r">

    <!-- C LINK -->
    <link name="Link_c_${side}">
      <visual>
        <geometry>
          <mesh filename="file://${pkg_share}/meshes/Link_c_${side}.STL"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="file://${pkg_share}/meshes/Link_c_${side}.STL"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="5.0"/>  
        <origin xyz="0 0 0"/>
        <inertia ixx="0.01" iyy="0.01" izz="0.01"
                 ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="Joint_c_${side}" type="revolute">
      <origin xyz="0 ${y_offset} 0" rpy="${rpy_c}"/>
      <parent link="${parent}"/>
      <child link="Link_c_${side}"/>
      <axis xyz="0 0 1"/>
      <limit lower="-1.5708" upper="1.5708" effort="100" velocity="5"/>  <!-- Restricted to ±90° -->
    </joint>

    <gazebo reference="Joint_c_${side}">
      <provideFeedback>true</provideFeedback>
    </gazebo>

    <!-- P LINK -->
    <link name="Link_p_${side}">
      <visual>
        <geometry>
          <mesh filename="file://${pkg_share}/meshes/Link_p_${side}.STL"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="file://${pkg_share}/meshes/Link_p_${side}.STL"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="15.0"/>  
        <origin xyz="0 0 0"/>
        <inertia ixx="0.01" iyy="0.01" izz="0.01"
                 ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="Joint_p_${side}" type="revolute">
      <origin xyz="-0.00013659 -0.099312 0.25" rpy="1.5708 0 -0.0013754"/>
      <parent link="Link_c_${side}"/>
      <child link="Link_p_${side}"/>
      <axis xyz="0 0 1"/>
      <limit lower="-1.5708" upper="1.5708" effort="100" velocity="5"/>  <!-- Restricted to ±90° -->
    </joint>

    <gazebo reference="Joint_p_${side}">
      <provideFeedback>true</provideFeedback>
    </gazebo>

    <!-- R LINK -->
    <link name="Link_r_${side}">
      <visual>
        <geometry>
          <mesh filename="file://${pkg_share}/meshes/Link_r_${side}.STL"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="file://${pkg_share}/meshes/Link_r_${side}.STL"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="8.0"/>  
        <origin xyz="0 0 0"/>
        <inertia ixx="0.01" iyy="0.01" izz="0.01"
                 ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="Joint_r_${side}" type="revolute">
      <origin xyz="0 1.6 0" rpy="${rpy_r}"/>
      <parent link="Link_p_${side}"/>
      <child link="Link_r_${side}"/>
      <axis xyz="0 0 1"/>
      <limit lower="-1.5708" upper="1.5708" effort="100" velocity="5"/>  <!-- Restricted to ±90° -->
    </joint>

    <gazebo reference="Joint_r_${side}">
      <provideFeedback>true</provideFeedback>
    </gazebo>

  </xacro:macro>

  <!-- ========================= -->
  <!-- LEGS -->
  <!-- ========================= -->
  <xacro:leg side="right" parent="base_link"
             y_offset="-0.8"
             rpy_c="1.5708 0 1.5708"
             rpy_r="3.1416 0 0"/>

  <xacro:leg side="left" parent="base_link"
             y_offset="0.8"
             rpy_c="1.5708 0 1.5708"
             rpy_r="-3.1416 0 0"/>

  <!-- ========================= -->
  <!-- ROS2 CONTROL -->
  <!-- ========================= -->
  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>

    <joint name="Joint_c_right">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="Joint_p_right">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="Joint_r_right">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="Joint_c_left">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="Joint_p_left">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="Joint_r_left">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

  </ros2_control>

  <!-- ========================= -->
  <!-- GAZEBO PLUGIN -->
  <!-- ========================= -->
  <gazebo>
    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
      <parameters>${controllers_yaml}</parameters>
    </plugin>
  </gazebo>

</robot>