<?xml version="1.0"?>
<robot name="planar_3dof_full" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- =====================================================
                            ARGUMENTS
       ===================================================== -->

  <xacro:arg name="pkg_share" default=""/>
  <xacro:arg name="controllers_yaml" default=""/>

  <xacro:property name="pkg_share" value="$(arg pkg_share)"/>
  <xacro:property name="controllers_yaml" value="$(arg controllers_yaml)"/>

  <!-- =====================================================
                       WORLD (Debugging)
       ===================================================== -->

<!--  <link name="world"/>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.5" rpy="1.5708 0 0"/>
  </joint> -->

  <!-- ===================================================== 
                            BASE LINK 
       ===================================================== -->

  <link name="base_link">

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.240693"/>
      <inertia
        ixx="0.001"
        iyy="0.001"
        izz="0.001"
        ixy="0"
        ixz="0"
        iyz="0"/>
    </inertial>

    <visual>
      <geometry>
        <mesh filename="file://${pkg_share}/meshes/base_link.STL"
              scale="1 1 1"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <mesh filename="file://${pkg_share}/meshes/base_link.STL"
              scale="1 1 1"/>
      </geometry>
    </collision>

  </link>

  <!-- ===================================================== 
                            LEFT LEG 
       ===================================================== -->

  <link name="Link_c_left">

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.076578"/>
      <inertia
        ixx="0.0005"
        iyy="0.0005"
        izz="0.0005"
        ixy="0"
        ixz="0"
        iyz="0"/>
    </inertial>

    <visual>
      <geometry>
        <mesh filename="file://${pkg_share}/meshes/Link_c_left.STL"
              scale="1 1 1"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <mesh filename="file://${pkg_share}/meshes/Link_c_left.STL"
              scale="1 1 1"/>
      </geometry>
    </collision>

  </link>

  <joint name="Joint_c_left" type="revolute">
    <origin xyz="0.0803 0 0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="Link_c_left"/>
    <axis xyz="0 0 1"/>

    <limit
      lower="-1.5708"
      upper="1.5708"
      effort="1000"
      velocity="2"/>

    <dynamics
      damping="300.0"
      friction="100.0"/>
  </joint>

  <link name="Link_p_left">

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.27292"/>
      <inertia
        ixx="0.001"
        iyy="0.001"
        izz="0.001"
        ixy="0"
        ixz="0"
        iyz="0"/>
    </inertial>

    <visual>
      <geometry>
        <mesh filename="file://${pkg_share}/meshes/Link_p_left.STL"
              scale="1 1 1"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <mesh filename="file://${pkg_share}/meshes/Link_p_left.STL"
              scale="1 1 1"/>
      </geometry>
    </collision>

  </link>

  <joint name="Joint_p_left" type="revolute">
    <origin xyz="0.0705 -0.017147 -0.00786"
            rpy="0 -1.5708 0"/>
    <parent link="Link_c_left"/>
    <child link="Link_p_left"/>
    <axis xyz="0 0 -1"/>

    <limit
      lower="-1.5708"
      upper="1.5708"
      effort="1000"
      velocity="2"/>

    <dynamics
      damping="300.0"
      friction="100.0"/>
  </joint>

  <link name="Link_r_left">

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.096277"/>
      <inertia
        ixx="0.0005"
        iyy="0.0005"
        izz="0.0005"
        ixy="0"
        ixz="0"
        iyz="0"/>
    </inertial>

    <visual>
      <geometry>
        <mesh filename="file://${pkg_share}/meshes/Link_r_left.STL"
              scale="1 1 1"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <mesh filename="file://${pkg_share}/meshes/Link_r_left.STL"
              scale="1 1 1"/>
      </geometry>
    </collision>

  </link>

  <joint name="Joint_r_left" type="revolute">
    <origin xyz="0 -0.13069 0"
            rpy="3.129 -0.00050149 -0.03981"/>
    <parent link="Link_p_left"/>
    <child link="Link_r_left"/>
    <axis xyz="0 0 1"/>

    <limit
      lower="-1.5708"
      upper="1.5708"
      effort="1000"
      velocity="2"/>

    <dynamics
      damping="300.0"
      friction="100.0"/>
  </joint>

  <link name="Link_wheels_left">

    <inertial>
      <origin xyz="0 0 -0.013" rpy="0 0 0"/>
      <mass value="0.065044"/>
      <inertia
        ixx="2.77E-05"
        iyy="2.77E-05"
        izz="4.9085E-05"
        ixy="0"
        ixz="0"
        iyz="0"/>
    </inertial>

    <visual>
      <geometry>
        <mesh filename="file://${pkg_share}/meshes/Link_wheels_left.STL"
              scale="1 1 1"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <mesh filename="file://${pkg_share}/meshes/Link_wheels_left.STL"
              scale="1 1 1"/>
      </geometry>
    </collision>

  </link>

  <joint name="Joint_wheels_left" type="continuous">
    <origin
      xyz="0.0049779 0.13502 0.0082029"
      rpy="0.0126 0 -0.039813"/>
    <parent link="Link_r_left"/>
    <child link="Link_wheels_left"/>
    <axis xyz="0 0 1"/>

    <limit
      effort="1000"
      velocity="20"/>

    <dynamics
      damping="3.0"
      friction="0.1"/>
  </joint>

  <!-- ===================================================== 
                           RIGHT LEG 
       ===================================================== -->

  <link name="Link_c_right">

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.077224"/>
      <inertia
        ixx="0.0005"
        iyy="0.0005"
        izz="0.0005"
        ixy="0"
        ixz="0"
        iyz="0"/>
    </inertial>

    <visual>
      <geometry>
        <mesh filename="file://${pkg_share}/meshes/Link_c_right.STL"
              scale="1 1 1"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <mesh filename="file://${pkg_share}/meshes/Link_c_right.STL"
              scale="1 1 1"/>
      </geometry>
    </collision>

  </link>

  <joint name="Joint_c_right" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="Link_c_right"/>
    <axis xyz="0 0 1"/>

    <limit
      lower="-1.5708"
      upper="1.5708"
      effort="1000"
      velocity="5"/>

    <dynamics
      damping="100.0"
      friction="50.0"/>
  </joint>

  <link name="Link_p_right">

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.27292"/>
      <inertia
        ixx="0.001"
        iyy="0.001"
        izz="0.001"
        ixy="0"
        ixz="0"
        iyz="0"/>
    </inertial>

    <visual>
      <geometry>
        <mesh filename="file://${pkg_share}/meshes/Link_p_right.STL"
              scale="1 1 1"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <mesh filename="file://${pkg_share}/meshes/Link_p_right.STL"
              scale="1 1 1"/>
      </geometry>
    </collision>

  </link>

  <joint name="Joint_p_right" type="revolute">
    <origin
      xyz="-0.0705 -0.015 -0.0077"
      rpy="-1.5708 -1.5555 1.5951"/>
    <parent link="Link_c_right"/>
    <child link="Link_p_right"/>
    <axis xyz="0 0 1"/>

    <limit
      lower="-1.5708"
      upper="1.5708"
      effort="1000"
      velocity="2"/>

    <dynamics
      damping="300.0"
      friction="100.0"/>
  </joint>

  <link name="Link_r_right">

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.096277"/>
      <inertia
        ixx="0.0005"
        iyy="0.0005"
        izz="0.0005"
        ixy="0"
        ixz="0"
        iyz="0"/>
    </inertial>

    <visual>
      <geometry>
        <mesh filename="file://${pkg_share}/meshes/Link_r_right.STL"
              scale="1 1 1"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <mesh filename="file://${pkg_share}/meshes/Link_r_right.STL"
              scale="1 1 1"/>
      </geometry>
    </collision>

  </link>

  <joint name="Joint_r_right" type="revolute">
    <origin
      xyz="-0.0019963 -0.13064 0.0031739"
      rpy="-3.1416 0 0.015536"/>
    <parent link="Link_p_right"/>
    <child link="Link_r_right"/>
    <axis xyz="0 0 -1"/>

    <limit
      lower="-1.5708"
      upper="1.5708"
      effort="1000"
      velocity="2"/>

    <dynamics
      damping="300.0"
      friction="100.0"/>
  </joint>

  <link name="Link_wheels_right">

    <inertial>
      <origin xyz="0 0 0.013" rpy="0 0 0"/>
      <mass value="0.065044"/>
      <inertia
        ixx="2.77E-05"
        iyy="2.77E-05"
        izz="4.9085E-05"
        ixy="0"
        ixz="0"
        iyz="0"/>
    </inertial>

    <visual>
      <geometry>
        <mesh filename="file://${pkg_share}/meshes/Link_wheels_right.STL"
              scale="1 1 1"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <mesh filename="file://${pkg_share}/meshes/Link_wheels_right.STL"
              scale="1 1 1"/>
      </geometry>
    </collision>

  </link>

  <joint name="Joint_wheels_right" type="continuous">
    <origin
      xyz="-0.0041596 0.13494 -0.0097816"
      rpy="-0.024288 0 0.030816"/>
    <parent link="Link_r_right"/>
    <child link="Link_wheels_right"/>
    <axis xyz="0 0 -1"/>

    <limit
      effort="1000"
      velocity="20"/>

    <dynamics
      damping="3.0"
      friction="0.1"/>
  </joint>

  <!-- ===================================================== 
                         ROS2 CONTROL
       ===================================================== -->

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>

    <joint name="Joint_c_right">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="Joint_p_right">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="Joint_r_right">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="Joint_c_left">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="Joint_p_left">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="Joint_r_left">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="Joint_wheels_left">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="Joint_wheels_right">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

  </ros2_control>


  <!-- ===================================================== 
                        GAZEBO ROS2 CONTROL 
       ===================================================== -->

  <gazebo>
    <plugin
        name="gazebo_ros2_control"
        filename="libgazebo_ros2_control.so">

      <parameters>$(arg controllers_yaml)</parameters>

    </plugin>
  </gazebo>
</robot>